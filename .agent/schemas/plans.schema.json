{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["plans"],
  "properties": {
    "plans": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "name",
          "route_path",
          "controller_path",
          "source",
          "status",
          "description"
        ],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "route_path": { "type": "string" },
          "controller_path": { "type": "string" },
          "source": { "enum": ["ai", "human"] },
          "description": { "type": "string" },
          "status": {
            "enum": ["open", "done", "done_but_need_human", "need_human"]
          },
          "status_details": {
            "type": "object",
            "properties": {
              "files_modified": {
                "type": "array",
                "items": { "type": "string" }
              },
              "notes": { "type": "string" }
            }
          }
        }
      }
    }
  }
}
